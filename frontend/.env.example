# Optional: override API URL (default: /api proxied to backend in dev)
VITE_API_URL=https://www.newznow.org/api

# Optional: OvenMediaEngine WebSocket URL.
# In production on HTTPS, prefer WSS and, if using the provided nginx config,
# point at your domain without a port so it goes through the /ome-ws proxy.
# Examples:
#   VITE_OME_WS_URL=wss://your-domain.com/ome-ws
#   VITE_OME_WS_URL=wss://your-ome-server:3333
# If not set, the app will default to:
#   - https://: wss://<current-host>/ome-ws
#   - http:// : ws://<current-host>:3333

# Studio return feed stream name (default: program)
# VITE_RETURN_FEED_STREAM=program

# STUN/TURN for WebRTC (NAT traversal). Reporter portal uses these for GO LIVE.
# Set to your server hostname or IP so mobile reporters can connect via Coturn.
# VITE_TURN_HOST=89.167.60.73
# VITE_TURN_USER=reporter
# VITE_TURN_PASSWORD=reporter123