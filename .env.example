# Module 1 root .env (docker/infra layer)
# This file is used by docker-compose services (OME/Coturn/restream).
# Application runtime variables are in:
# - backend/.env
# - frontend/.env

# Server public IP for WebRTC ICE (OME)
OME_HOST_IP=*

# Server public IP for TURN (Coturn). Required for mobile reporters behind NAT.
# Example: TURN_EXTERNAL_IP=203.0.113.10
TURN_EXTERNAL_IP=

# Optional: SRT program input URL used by restream-forwarder (inside Docker network).
# Default is usually fine if OME uses app "live" and stream "program".
PROGRAM_SRT_INPUT_URL=srt://ome:9999?streamid=live/program

# Required only if you want server->Restream distribution.
# Format: rtmp://live.restream.io/live/<YOUR_STREAM_KEY>
RESTREAM_RTMP_URL=

# -----------------------------------------------------------
# Cross-module integration (Module 1 -> Module 2)
# NOTE: these are read by backend/.env in runtime.
# Keep these values synchronized there.
# -----------------------------------------------------------
MODULE2_URL=http://204.168.181.42
MODULE2_WEBHOOK_SECRET=replace-with-module2-shared-secret
UPLOAD_PUBLIC_BASE_URL=https://www.newznow.org
