<?xml version="1.0" encoding="UTF-8"?>
<Server version="9">
	<Name>OvenMediaEngine</Name>
	<IP>*</IP>
	<PrivacyProtection>false</PrivacyProtection>
	<!-- STUN: use Coturn for NAT traversal (same host as TURN for reporters) -->
	<StunServer>coturn:3478</StunServer>
	<!-- REST API: monitoring (stats) and recording control. Auth: Basic access_token -->
	<Managers>
		<API>
			<AccessToken>ome-admin:changeme</AccessToken>
		</API>
	</Managers>
	<Bind>
		<Managers>
			<API>
				<Port>9999</Port>
			</API>
		</Managers>
		<Providers>
			<!-- WebRTC ingest only; RTMP ingest disabled (port 1935 used by nginx-rtmp) -->
			<WebRTC>
				<Signalling>
					<Port>3333</Port>
					<TLSPort>3334</TLSPort>
					<!-- 4 workers for ~20 concurrent publisher connections -->
					<WorkerCount>4</WorkerCount>
				</Signalling>
				<IceCandidates>
					<!-- OME embedded TURN on 3479 (Coturn uses 3478) -->
					<TcpRelay>*:3479</TcpRelay>
					<TcpForce>false</TcpForce>
					<!-- 20 UDP ports for 20 concurrent WebRTC publishers -->
					<IceCandidate>*:10000-10019/udp</IceCandidate>
				</IceCandidates>
			</WebRTC>
		</Providers>
		<Publishers>
			<WebRTC>
				<Signalling>
					<Port>3333</Port>
					<TLSPort>3334</TLSPort>
					<WorkerCount>4</WorkerCount>
				</Signalling>
				<IceCandidates>
					<TcpRelay>*:3479</TcpRelay>
					<TcpForce>false</TcpForce>
					<IceCandidate>*:10000-10019/udp</IceCandidate>
				</IceCandidates>
			</WebRTC>
			<HLS>
				<Port>80</Port>
				<TLSPort>443</TLSPort>
			</HLS>
			<!-- Optional stream recording (start/stop via REST API) -->
			<FILE>
				<RootPath>/var/lib/ovenmediaengine/records</RootPath>
				<FilePath>/${VirtualHost}/${Application}/${Stream}/${StartTime:YYYYMMDDhhmmss}_${EndTime:YYYYMMDDhhmmss}.ts</FilePath>
				<InfoPath>/${VirtualHost}/${Application}/${Stream}_info.xml</InfoPath>
			</FILE>
		</Publishers>
	</Bind>
	<VirtualHosts>
		<VirtualHost>
			<Name>*</Name>
			<Host>
				<Names>
					<Name>*</Name>
				</Names>
				<TLS>
					<CertPath>/opt/ovenmediaengine/bin/origin_conf/cert.pem</CertPath>
					<KeyPath>/opt/ovenmediaengine/bin/origin_conf/key.pem</KeyPath>
				</TLS>
			</Host>
			<Applications>
				<Application>
					<Name>live</Name>
					<Type>live</Type>
					<Providers>
						<WebRTC>
							<Timeout>30000</Timeout>
							<FIRInterval>3000</FIRInterval>
							<CrossDomains>
								<Url>*</Url>
							</CrossDomains>
						</WebRTC>
					</Providers>
					<Publishers>
						<Push>
							<StreamMap>
								<Enable>true</Enable>
								<Path>StreamMap.xml</Path>
							</StreamMap>
						</Push>
					</Publishers>
					<OutputProfiles>
						<!-- Decoder: 8 threads for 20 concurrent streams -->
						<Decodes>
							<ThreadCount>8</ThreadCount>
						</Decodes>
						<!-- WebRTC playback: bypass for lowest latency -->
						<OutputProfile>
							<Name>bypass</Name>
							<OutputStreamName>${OriginStreamName}</OutputStreamName>
							<Encodes>
								<Video>
									<Bypass>true</Bypass>
								</Video>
								<Audio>
									<Name>opus_audio</Name>
									<Codec>opus</Codec>
									<Bitrate>128000</Bitrate>
									<Samplerate>48000</Samplerate>
									<Channel>2</Channel>
									<BypassIfMatch>
										<Codec>eq</Codec>
									</BypassIfMatch>
								</Audio>
							</Encodes>
						</OutputProfile>
						<!-- RTMP output: H264 + AAC for vMix/OBS (push to nginx-rtmp) -->
						<OutputProfile>
							<Name>rtmp</Name>
							<OutputStreamName>${OriginStreamName}_rtmp</OutputStreamName>
							<Encodes>
								<Video>
									<Name>video_h264</Name>
									<Codec>h264</Codec>
									<Width>1280</Width>
									<Height>720</Height>
									<Bitrate>2000000</Bitrate>
									<Framerate>30</Framerate>
									<KeyFrameInterval>30</KeyFrameInterval>
									<BFrames>0</BFrames>
									<Preset>fast</Preset>
								</Video>
								<Audio>
									<Name>audio_aac</Name>
									<Codec>aac</Codec>
									<Bitrate>128000</Bitrate>
									<Samplerate>48000</Samplerate>
									<Channel>2</Channel>
								</Audio>
							</Encodes>
						</OutputProfile>
					</OutputProfiles>
				</Application>
			</Applications>
		</VirtualHost>
	</VirtualHosts>
</Server>
