PORT=4000
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require
JWT_SECRET=replace-with-strong-secret

# Administrator (login at /admin; can add reporters and editors)
ADMIN_EMAIL=admin@newsroom.local
ADMIN_PASSWORD=AdminSecurePassword123!

# Optional: use bcrypt hash instead of plain password (run: node -e "console.log(require('bcryptjs').hashSync('YourPassword', 10))")
# ADMIN_PASSWORD_HASH=

# Editors (role: editor; cannot add/remove editors or reporters)
SEED_EDITOR_EMAIL=editor@newsroom.local
SEED_EDITOR_PASSWORD=Editor123!
SEED_EDITOR_NAME=Newsroom Editor

# Max upload size (MB); default 300
UPLOAD_MAX_SIZE_MB=300

# Optional: object storage (Hetzner Object Storage or other S3-compatible)
OBJECT_STORAGE_ENDPOINT=https://your-endpoint
OBJECT_STORAGE_REGION=eu-central-1
OBJECT_STORAGE_BUCKET=newsroom-uploads
OBJECT_STORAGE_ACCESS_KEY=your-access-key
OBJECT_STORAGE_SECRET_KEY=your-secret-key
OBJECT_STORAGE_PATH_STYLE=true

# Optional: streaming limits and outputs
MAX_CONCURRENT_STREAMS=20

# OvenMediaEngine WebSocket base for newsroom previews (editor pages)
# Example (no proxy): ws://your-ome-host:3333
# If you use the /ome-ws nginx proxy on the same domain as the dashboards,
# you can leave this unset and the default ws://localhost:3333 will work on the server side
# while the frontend uses VITE_OME_WS_URL / /ome-ws.
RTMP_BASE_URL=rtmp://www.newznow.org/live
OME_WS_BASE_URL=ws://127.0.0.1:3333
SRT_BASE_URL=srt://www.newznow.org:port/live
RETURN_FEED_STREAM=program